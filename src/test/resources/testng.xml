<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
    parallel="methods" + thread-count="3": TestNG runs each @Test method on its
    own thread. This is what forces DriverFactory to be ThreadLocal - if it
    weren't, two threads would stomp on the same "driver" field and you'd get
    NoSuchSessionException / element-not-attached type flakiness that's a classic
    "explain a flaky test you fixed" interview story.
-->
<suite name="GridSuite" parallel="methods" thread-count="3">
    <test name="RegressionTests">
        <classes>
            <class name="com.tests.LoginTest"/>
            <class name="com.tests.DropdownTest"/>
            <class name="com.tests.CheckboxTest"/>
        </classes>
    </test>
</suite>
